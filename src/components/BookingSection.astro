---
import { type Lang, useTranslations } from '../i18n/index';
import BookingEmbed from './BookingEmbed.tsx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="booking" class="py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block text-gold text-sm font-semibold uppercase tracking-widest mb-3">Book</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy mb-4">
        {t('booking.title')}
      </h2>
      <p class="text-slate-500 text-lg max-w-2xl mx-auto">
        {t('booking.subtitle')}
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 overflow-hidden">
      <BookingEmbed client:load calLink="mujiri" calOrigin="https://cal.eu" />
    </div>
  </div>
</section>

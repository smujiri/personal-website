---
import { type Lang, useTranslations } from '../i18n/index';
import BookingEmbed from './BookingEmbed.tsx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="booking" class="py-28 bg-cream-light border-t border-cream-dark">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14 pb-8 border-b border-cream-dark">
      <div>
        <p class="label mb-3">Book</p>
        <h2 class="font-display font-black text-charcoal uppercase text-4xl sm:text-5xl leading-none tracking-tight">
          {t('booking.title')}
        </h2>
      </div>
      <p class="text-charcoal-muted text-sm leading-relaxed max-w-xs font-light">
        {t('booking.subtitle')}
      </p>
    </div>

    <div class="border border-cream-dark overflow-hidden bg-white">
      <BookingEmbed client:load calLink="mujiri" calOrigin="https://cal.eu" />
    </div>
  </div>
</section>

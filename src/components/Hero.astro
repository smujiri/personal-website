---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const orgs = [
  { name: 'EUIPO', logo: '/logos/euipo.svg' },
  { name: 'WIPO', logo: '/logos/wipo.svg' },
  { name: 'INTA', logo: '/logos/inta.svg' },
  { name: 'SAKPATENTI', logo: '/logos/sakpatenti.svg' },
];
---

<section class="relative min-h-screen flex flex-col overflow-hidden bg-charcoal">

  <!-- Silk texture -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/silk.png')"
    aria-hidden="true"
  ></div>
  <!-- Subtle overlay — less than before so the silk breathes -->
  <div class="absolute inset-0 bg-charcoal/40" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative flex-1 flex flex-col max-w-7xl mx-auto w-full px-6 lg:px-10 pt-16">

    <!-- Tagline top-right — much larger, the brand's voice -->
    <div class="hero-tagline flex justify-end pt-10 mb-auto">
      <p class="font-display font-black text-white uppercase leading-none text-3xl sm:text-5xl lg:text-6xl tracking-tight text-right">
        PROTECT NOW.<br />LEAD TOMORROW.
      </p>
    </div>

    <!-- Main content centre -->
    <div class="flex-1 flex flex-col justify-center py-16 lg:py-24 max-w-4xl">
      <p class="hero-label font-display text-xs font-semibold uppercase tracking-widest2 text-white/40 mb-5">
        Intellectual Property Advisory
      </p>
      <h1 class="hero-heading font-display font-black text-white uppercase leading-none text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] mb-8 tracking-tight">
        {t('hero.headline')}
      </h1>
      <p class="hero-sub text-white/55 text-base sm:text-lg max-w-lg mb-12 font-light leading-relaxed">
        {t('hero.subheadline')}
      </p>
      <div class="hero-ctas flex flex-col sm:flex-row gap-3">
        <a
          href="#booking"
          class="bg-white text-charcoal font-display font-bold text-xs uppercase tracking-widest px-8 py-4 hover:bg-cream transition-colors duration-200 text-center"
        >
          {t('hero.cta.primary')}
        </a>
        <a
          href="#services"
          class="border border-white/25 text-white font-display font-semibold text-xs uppercase tracking-widest px-8 py-4 hover:bg-white/8 transition-colors duration-200 text-center"
        >
          {t('hero.cta.secondary')}
        </a>
      </div>
    </div>

    <!-- SM monogram bottom-left -->
    <div class="hero-monogram pb-8 select-none" aria-hidden="true">
      <span class="font-display font-black text-white/15 leading-none uppercase"
        style="font-size: clamp(6rem, 15vw, 12rem); line-height: 1;">
        SM
      </span>
    </div>
  </div>

  <!-- Institutions strip -->
  <div class="relative border-t border-white/10 bg-black/30 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-7">
      <p class="font-display text-xs font-semibold uppercase tracking-widest2 text-white/25 mb-5">
        Partner institutions & affiliations
      </p>
      <div class="flex flex-wrap items-center gap-8 sm:gap-12">
        {orgs.map(({ name, logo }) => (
          <img
            src={logo}
            alt={name}
            height="28"
            class="h-6 sm:h-7 w-auto object-contain opacity-35 hover:opacity-65 transition-opacity duration-300 brightness-0 invert"
          />
        ))}
      </div>
    </div>
  </div>
</section>

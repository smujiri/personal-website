---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    key: 'service1',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10h1v11H4M9 10h1v11H9M14 10h1v11h-1M19 10h1v11h-1"/></svg>`,
  },
  {
    key: 'service2',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  },
  {
    key: 'service3',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    key: 'service4',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3" stroke-width="1.5"/></svg>`,
  },
  {
    key: 'service5',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
  },
] as const;
---

<section id="services" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block text-gold text-sm font-semibold uppercase tracking-widest mb-3">Expertise</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy mb-4">
        {t('services.title')}
      </h2>
      <p class="text-slate-500 text-lg max-w-2xl mx-auto">
        {t('services.subtitle')}
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(({ key, icon }, index) => (
        <article
          class={`group relative bg-white border border-slate-100 rounded-2xl p-8 hover:border-gold/40 hover:shadow-xl hover:shadow-navy/5 transition-all duration-300 ${
            index === 4 ? 'md:col-span-2 lg:col-span-1' : ''
          }`}
        >
          <!-- Icon -->
          <div class="w-12 h-12 bg-navy/5 group-hover:bg-gold/10 rounded-xl flex items-center justify-center text-navy group-hover:text-gold transition-colors mb-6">
            <Fragment set:html={icon} />
          </div>

          <!-- Content -->
          <h3 class="font-serif text-lg font-semibold text-navy mb-3 leading-snug">
            {t(`${key}.title` as any)}
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            {t(`${key}.desc` as any)}
          </p>

          <!-- Hover accent -->
          <div class="absolute bottom-0 left-8 right-8 h-0.5 bg-gradient-to-r from-gold to-gold-light scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-full"></div>
        </article>
      ))}
    </div>
  </div>
</section>

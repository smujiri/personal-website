---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  { key: 'service1', num: '01' },
  { key: 'service2', num: '02' },
  { key: 'service3', num: '03' },
  { key: 'service4', num: '04' },
  { key: 'service5', num: '05' },
] as const;
---

<section id="services" class="py-28 bg-cream-light">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="reveal flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-16 pb-8 border-b border-cream-dark">
      <div>
        <p class="label mb-3">Expertise</p>
        <h2 class="font-display font-black text-charcoal uppercase text-4xl sm:text-5xl leading-none tracking-tight">
          {t('services.title')}
        </h2>
      </div>
      <p class="text-charcoal-muted text-sm leading-relaxed max-w-xs font-light">
        {t('services.subtitle')}
      </p>
    </div>

    <!-- Services list -->
    <div class="divide-y divide-cream-dark">
      {services.map(({ key, num }, i) => (
        <article
          class={`reveal reveal-delay-${Math.min(i + 1, 4)} group grid grid-cols-12 gap-x-6 gap-y-2 py-8 -mx-6 px-6 cursor-default`}
          style={`--hover-bg: #EDE7DB;`}
        >
          <!-- Hover background via JS-free approach -->
          <div class="absolute inset-0 bg-cream opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10 pointer-events-none"></div>

          <!-- Number -->
          <div class="col-span-2 sm:col-span-1 flex items-start pt-0.5">
            <span class="font-display font-light text-charcoal-muted text-xs tracking-widest">{num}</span>
          </div>

          <!-- Title -->
          <div class="col-span-10 sm:col-span-4 flex items-start">
            <h3 class="font-display font-bold text-charcoal uppercase text-sm leading-snug tracking-tight group-hover:translate-x-1 transition-transform duration-300">
              {t(`${key}.title` as any)}
            </h3>
          </div>

          <!-- Description -->
          <div class="col-span-12 sm:col-span-6 sm:col-start-6 flex items-start">
            <p class="text-charcoal-muted text-sm leading-relaxed font-light">
              {t(`${key}.desc` as any)}
            </p>
          </div>

          <!-- Arrow — fixed: single transition-all -->
          <div class="hidden sm:flex col-span-12 sm:col-span-1 items-start justify-end pt-0.5">
            <svg
              class="w-4 h-4 text-charcoal opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
              fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

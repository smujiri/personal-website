---
import { type Lang, languages, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const langPaths: Record<Lang, string> = {
  en: '/en/',
  ka: '/ka/',
  ru: '/ru/',
  de: '/de/',
  es: '/es/',
};
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href={`/${lang}/`} class="font-serif text-xl font-bold text-navy shrink-0">
      IP <span class="text-gold">Consulting</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6 lg:gap-8">
      <a href={`/${lang}/#services`} class="text-sm text-slate-600 hover:text-navy transition-colors font-medium">
        {t('nav.services')}
      </a>
      <a href={`/${lang}/#about`} class="text-sm text-slate-600 hover:text-navy transition-colors font-medium">
        {t('nav.about')}
      </a>
      <a href={`/${lang}/#insights`} class="text-sm text-slate-600 hover:text-navy transition-colors font-medium">
        {t('nav.insights')}
      </a>

      <!-- Language switcher -->
      <div class="relative group">
        <button
          class="flex items-center gap-1.5 text-sm text-slate-600 hover:text-navy transition-colors font-medium uppercase tracking-wide"
          aria-label="Switch language"
        >
          {lang}
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-2 w-40 bg-white border border-slate-100 rounded-xl shadow-lg ring-1 ring-black/5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 py-1">
          {Object.entries(languages).map(([code, name]) => (
            <a
              href={langPaths[code as Lang]}
              class={`flex items-center gap-2 px-4 py-2 text-sm transition-colors ${
                code === lang
                  ? 'text-navy font-semibold bg-slate-50'
                  : 'text-slate-600 hover:bg-slate-50 hover:text-navy'
              }`}
            >
              <span class="uppercase text-xs font-mono text-slate-400 w-6">{code}</span>
              {name}
            </a>
          ))}
        </div>
      </div>

      <a
        href={`/${lang}/#booking`}
        class="bg-navy text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-navy-light transition-colors whitespace-nowrap"
      >
        {t('nav.book')}
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-slate-600 hover:text-navy rounded-lg hover:bg-slate-50 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-100 bg-white"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-3">
      <a href={`/${lang}/#services`} class="py-2 text-slate-700 hover:text-navy font-medium transition-colors">{t('nav.services')}</a>
      <a href={`/${lang}/#about`} class="py-2 text-slate-700 hover:text-navy font-medium transition-colors">{t('nav.about')}</a>
      <a href={`/${lang}/#insights`} class="py-2 text-slate-700 hover:text-navy font-medium transition-colors">{t('nav.insights')}</a>
      <div class="pt-2 pb-1 border-t border-slate-100">
        <p class="text-xs text-slate-400 uppercase tracking-wider mb-2 font-medium">Language</p>
        <div class="flex flex-wrap gap-2">
          {Object.entries(languages).map(([code, name]) => (
            <a
              href={langPaths[code as Lang]}
              class={`px-3 py-1 text-sm rounded-lg border transition-colors ${
                code === lang
                  ? 'bg-navy text-white border-navy'
                  : 'border-slate-200 text-slate-600 hover:border-navy hover:text-navy'
              }`}
            >
              {name}
            </a>
          ))}
        </div>
      </div>
      <a
        href={`/${lang}/#booking`}
        class="bg-navy text-white px-5 py-3 rounded-lg text-sm font-semibold text-center hover:bg-navy-light transition-colors mt-1"
      >
        {t('nav.book')}
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
    toggle.setAttribute('aria-expanded', String(isHidden));
  });

  // Close menu on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>

---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="insights" class="py-24 bg-navy relative overflow-hidden">
  <!-- Background decoration -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 80% at 90% 50%, rgba(196,168,75,0.08) 0%, transparent 70%)"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Text -->
      <div>
        <span class="inline-flex items-center gap-2 bg-gold/15 text-gold border border-gold/20 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
          </svg>
          {t('leadmagnet.badge')}
        </span>

        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-5 leading-tight">
          {t('leadmagnet.title')}
        </h2>

        <p class="text-slate-300 leading-relaxed mb-8">
          {t('leadmagnet.body')}
        </p>

        <!-- What you'll get -->
        <ul class="space-y-2 text-slate-300 text-sm">
          {[
            'EU IP acquis overview & compliance checklist',
            'Trademark & patent registration roadmap',
            'Cross-border enforcement best practices',
            'GI protection framework summary',
          ].map(item => (
            <li class="flex items-center gap-2.5">
              <span class="w-4 h-4 rounded-full bg-gold/20 border border-gold/30 flex items-center justify-center shrink-0">
                <svg class="w-2.5 h-2.5 text-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Form card -->
      <div class="bg-white rounded-2xl p-8 shadow-2xl shadow-black/20">
        <h3 class="font-serif text-xl font-bold text-navy mb-2">Get the free guide</h3>
        <p class="text-slate-500 text-sm mb-6">Delivered to your inbox instantly.</p>

        <form
          id="lead-form"
          class="flex flex-col gap-4"
          novalidate
        >
          <div>
            <label for="lead-email" class="sr-only">Email address</label>
            <input
              id="lead-email"
              name="email"
              type="email"
              required
              placeholder={t('leadmagnet.placeholder')}
              class="w-full px-4 py-3.5 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors text-sm"
            />
          </div>
          <button
            type="submit"
            class="w-full bg-gold hover:bg-gold-dark text-navy font-bold px-6 py-3.5 rounded-xl transition-colors text-sm shadow-md shadow-gold/20"
          >
            {t('leadmagnet.cta')}
          </button>
        </form>

        <!-- Success state (hidden by default) -->
        <div id="lead-success" class="hidden text-center py-4">
          <div class="w-12 h-12 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-navy font-semibold mb-1">{t('leadmagnet.success')}</p>
          <p class="text-slate-400 text-sm">{t('leadmagnet.privacy')}</p>
        </div>

        <p class="text-slate-400 text-xs text-center mt-4">
          {t('leadmagnet.privacy')}
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const success = document.getElementById('lead-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    if (!email || !email.includes('@')) return;
    // TODO: Connect to your email provider (ConvertKit, Mailchimp, etc.)
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>

---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="insights" class="py-28 bg-cream-light border-t border-cream-dark">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">

      <!-- Text -->
      <div>
        <p class="label mb-4">{t('leadmagnet.badge')}</p>
        <h2 class="font-display font-black text-charcoal uppercase text-4xl sm:text-5xl leading-none tracking-tight mb-8">
          {t('leadmagnet.title')}
        </h2>
        <p class="text-charcoal-muted text-sm leading-relaxed font-light mb-10 max-w-sm">
          {t('leadmagnet.body')}
        </p>

        <!-- What's inside -->
        <ul class="space-y-0 divide-y divide-cream-dark">
          {[
            'EU IP acquis overview & compliance checklist',
            'Trademark & patent registration roadmap',
            'Cross-border enforcement best practices',
            'GI protection framework summary',
          ].map(item => (
            <li class="flex items-center gap-4 py-4">
              <span class="font-display font-black text-charcoal-muted text-xs">—</span>
              <span class="font-display text-charcoal text-sm font-medium uppercase tracking-wide">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Form -->
      <div class="bg-charcoal p-10">
        <h3 class="font-display font-black text-white uppercase text-2xl leading-none tracking-tight mb-2">
          Get the free guide
        </h3>
        <p class="font-display text-white/40 text-xs uppercase tracking-widest mb-8">
          Delivered to your inbox instantly.
        </p>

        <form id="lead-form" class="flex flex-col gap-4" novalidate>
          <label for="lead-email" class="sr-only">Email address</label>
          <input
            id="lead-email"
            name="email"
            type="email"
            required
            placeholder={t('leadmagnet.placeholder')}
            class="w-full bg-white/8 border border-white/15 text-white placeholder-white/30 px-4 py-3.5 text-sm font-display focus:outline-none focus:border-white/40 transition-colors"
          />
          <button
            type="submit"
            class="w-full bg-white text-charcoal font-display font-bold text-xs uppercase tracking-widest px-6 py-4 hover:bg-cream transition-colors"
          >
            {t('leadmagnet.cta')}
          </button>
        </form>

        <div id="lead-success" class="hidden py-6 text-center">
          <p class="font-display font-bold text-white uppercase tracking-wide text-sm mb-1">{t('leadmagnet.success')}</p>
        </div>

        <p class="font-display text-white/25 text-xs uppercase tracking-widest mt-6">
          {t('leadmagnet.privacy')}
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const success = document.getElementById('lead-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    if (!email || !email.includes('@')) return;
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>

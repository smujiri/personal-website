---
import { type Lang, languages, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

const langPaths: Record<Lang, string> = {
  en: '/en/', ka: '/ka/', ru: '/ru/', de: '/de/', es: '/es/',
};

const navLinks = [
  { href: `/${lang}/#services`, label: t('nav.services') },
  { href: `/${lang}/#about`, label: t('nav.about') },
  { href: `/${lang}/#insights`, label: t('nav.insights') },
  { href: `/${lang}/#booking`, label: t('nav.book') },
];
---

<footer class="bg-navy border-t border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer -->
    <div class="py-14 grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`/${lang}/`} class="font-serif text-2xl font-bold text-white">
          IP <span class="text-gold">Consulting</span>
        </a>
        <p class="text-slate-400 text-sm mt-3 leading-relaxed">
          {t('footer.tagline')}
        </p>

        <!-- Social placeholder -->
        <div class="flex gap-3 mt-5">
          {[
            { label: 'LinkedIn', icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
          ].map(({ label, icon }) => (
            <a
              href="#"
              aria-label={label}
              class="w-9 h-9 bg-white/10 hover:bg-gold/20 text-slate-400 hover:text-gold rounded-lg flex items-center justify-center transition-colors"
            >
              <Fragment set:html={icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white text-sm font-semibold uppercase tracking-widest mb-4">{t('footer.nav.title')}</h4>
        <ul class="space-y-2.5">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-slate-400 hover:text-white text-sm transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal & Languages -->
      <div>
        <h4 class="text-white text-sm font-semibold uppercase tracking-widest mb-4">{t('footer.legal.title')}</h4>
        <ul class="space-y-2.5 mb-8">
          <li>
            <a href={`/${lang}/privacy`} class="text-slate-400 hover:text-white text-sm transition-colors">
              {t('footer.privacy')}
            </a>
          </li>
          <li>
            <a href={`/${lang}/terms`} class="text-slate-400 hover:text-white text-sm transition-colors">
              {t('footer.terms')}
            </a>
          </li>
        </ul>

        <!-- Language list -->
        <div class="flex flex-wrap gap-2">
          {Object.entries(languages).map(([code, name]) => (
            <a
              href={langPaths[code as Lang]}
              class={`px-3 py-1 text-xs rounded-lg border transition-colors ${
                code === lang
                  ? 'bg-gold/20 text-gold border-gold/30'
                  : 'border-white/10 text-slate-500 hover:border-white/30 hover:text-slate-300'
              }`}
            >
              {name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-2 text-slate-500 text-xs">
      <span>&copy; {year} IP Consulting. {t('footer.rights')}</span>
      <span class="flex gap-4">
        <a href={`/${lang}/privacy`} class="hover:text-slate-300 transition-colors">{t('footer.privacy')}</a>
        <a href={`/${lang}/terms`} class="hover:text-slate-300 transition-colors">{t('footer.terms')}</a>
      </span>
    </div>
  </div>
</footer>

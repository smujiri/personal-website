---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

const navLinks = [
  { href: '/#services', label: t('nav.services') },
  { href: '/#about', label: t('nav.about') },
  { href: '/#booking', label: t('nav.book') },
];

const contact = [
  { key: 'L.', value: 'Tbilisi, Georgia · Madrid, Spain' },
  { key: 'E.', value: 'sophio@mujiri.ge' },
  { key: 'W.', value: 'www.mujiri.ge' },
  { key: 'T.', value: '+995 555 955550 · +34 652655361' },
];
---

<footer class="bg-charcoal text-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Main footer -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-14 border-b border-white/10">

      <!-- Brand -->
      <div>
        <a href="/" class="font-display font-bold text-white text-lg tracking-tight inline-block mb-4">
          SM <span class="font-light text-white/40">CONSULTING</span>
        </a>
        <p class="font-display text-white/30 text-xs uppercase tracking-widest leading-relaxed">
          {t('footer.tagline')}
        </p>

        <div class="flex gap-3 mt-8">
          <a
            href="https://www.linkedin.com/in/sophio-mujiri/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-9 h-9 border border-white/15 text-white/40 hover:text-white hover:border-white/40 flex items-center justify-center transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-white/30 mb-6">
          {t('footer.nav.title')}
        </p>
        <ul class="space-y-3">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="font-display text-xs font-semibold uppercase tracking-widest text-white/50 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact — in the card's L./E./W./T. format -->
      <div>
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-white/30 mb-6">
          Contact
        </p>
        <ul class="space-y-4">
          {contact.map(({ key, value }) => (
            <li class="flex items-start gap-4">
              <span class="font-display font-bold text-white/30 text-xs w-6 shrink-0 pt-0.5">{key}</span>
              <span class="font-display text-white/60 text-xs leading-relaxed">{value}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-white/25 text-xs font-display uppercase tracking-widest">
      <span>&copy; {year} SM Consulting. {t('footer.rights')}</span>
      <span class="flex gap-6">
        <a href="/privacy" class="hover:text-white/50 transition-colors">{t('footer.privacy')}</a>
        <a href="/terms" class="hover:text-white/50 transition-colors">{t('footer.terms')}</a>
      </span>
    </div>
  </div>
</footer>

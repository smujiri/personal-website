---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const credentials = ['about.cred1', 'about.cred2', 'about.cred3', 'about.cred4'] as const;
const stats = [
  { value: 'about.years', label: 'about.years.label' },
  { value: 'about.clients', label: 'about.clients.label' },
  { value: 'about.programs', label: 'about.programs.label' },
] as const;
---

<section id="about" class="py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text content -->
      <div>
        <span class="inline-block text-gold text-sm font-semibold uppercase tracking-widest mb-3">About</span>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy mb-3 leading-tight">
          {t('about.title')}
        </h2>
        <p class="text-slate-500 text-base mb-6 italic">{t('about.subtitle')}</p>
        <p class="text-slate-600 leading-relaxed mb-8">
          {t('about.body')}
        </p>

        <!-- Credentials -->
        <ul class="space-y-3 mb-10">
          {credentials.map(key => (
            <li class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-gold/15 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="text-slate-700 text-sm font-medium">{t(key)}</span>
            </li>
          ))}
        </ul>

        <a
          href="#booking"
          class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-xl font-semibold hover:bg-navy-light transition-colors text-sm"
        >
          Work Together
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Visual column -->
      <div class="flex flex-col gap-6">

        <!-- Portrait -->
        <div class="relative rounded-2xl overflow-hidden aspect-[4/5] bg-slate-100">
          <img
            src="/portrait.jpg"
            alt="Consultant portrait"
            class="w-full h-full object-cover object-top"
          />
          <!-- Gold accent bar -->
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-gold to-gold-light"></div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4">
          {stats.map(({ value, label }) => (
            <div class="bg-white rounded-2xl p-5 text-center border border-slate-100 shadow-sm">
              <div class="font-serif text-2xl font-bold text-navy mb-1">{t(value)}</div>
              <div class="text-slate-500 text-xs leading-tight">{t(label)}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = `/${lang}`;

const credentials = ['about.cred1', 'about.cred2', 'about.cred3', 'about.cred4'] as const;
const stats = [
  { value: 'about.years', label: 'about.years.label' },
  { value: 'about.clients', label: 'about.clients.label' },
  { value: 'about.programs', label: 'about.programs.label' },
] as const;
---

<section id="about" class="bg-charcoal text-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Main grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 pt-28 pb-20 border-b border-white/10">

      <!-- Left: text -->
      <div class="reveal flex flex-col justify-between">
        <div>
          <p class="font-display text-xs font-semibold uppercase tracking-widest2 text-white/30 mb-6">About</p>
          <h2 class="font-display font-black text-white uppercase text-4xl sm:text-5xl leading-none tracking-tight mb-10">
            {t('about.title')}
          </h2>
          <p class="text-white/45 text-sm font-light leading-[1.85] mb-10">
            {t('about.body')}
          </p>
        </div>
        <a
          href={`${base}/#booking`}
          class="inline-flex items-center gap-3 self-start bg-white text-charcoal font-display font-bold text-xs uppercase tracking-widest px-6 py-3.5 hover:bg-cream transition-colors duration-200"
        >
          Work Together
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: portrait + credentials -->
      <div class="reveal reveal-delay-2 flex flex-col gap-8">

        <!-- Portrait -->
        <div class="relative overflow-hidden bg-charcoal-light" style="aspect-ratio: 3/4;">
          <img
            src="/portrait.jpg"
            alt="Sophio Mujiri"
            class="w-full h-full object-cover object-top scale-[1.01] hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/50 via-transparent to-transparent"></div>
        </div>

        <!-- Credentials list -->
        <ul class="divide-y divide-white/10">
          {credentials.map((key, i) => (
            <li class="flex items-center gap-4 py-3.5">
              <span class="font-display font-light text-white/25 text-xs tracking-widest w-6 shrink-0 tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-display font-semibold text-white/70 text-xs uppercase tracking-widest">
                {t(key)}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Stats row -->
    <div class="reveal grid grid-cols-1 sm:grid-cols-3 gap-0 py-14 border-b border-white/10 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
      {stats.map(({ value, label }) => (
        <div class="py-6 sm:py-0 sm:px-8 first:pt-0 last:pb-0 sm:first:pl-0 sm:last:pr-0">
          <div class="font-display font-black text-white text-5xl sm:text-5xl leading-none mb-3 tabular-nums">
            {t(value)}
          </div>
          <div class="font-display text-xs font-medium uppercase tracking-widest text-white/30 leading-relaxed">
            {t(label)}
          </div>
        </div>
      ))}
    </div>

    <!-- Name watermark -->
    <div class="reveal py-10 overflow-hidden">
      <p class="font-display font-black text-white/10 uppercase leading-none tracking-tight select-none"
        style="font-size: clamp(2rem, 7vw, 7rem);">
        SOPHIO MUJIRI
      </p>
      <p class="font-display font-medium text-white/25 uppercase tracking-widest text-xs mt-3">
        Patent & Trademark Attorney · IP Consultant
      </p>
    </div>

  </div>
</section>

---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    quote: "Working with this consultant transformed our approach to IP protection in the EU market. Her insights on acquis harmonization were invaluable for our expansion strategy.",
    name: "Dr. Andrea Müller",
    role: "Director of Legal Affairs",
    org: "European Pharmaceutical Group",
  },
  {
    quote: "As a WIPO representative, I have collaborated alongside her at numerous international forums. Her expertise in GI frameworks and commitment to capacity building is unmatched in the region.",
    name: "James K. Osei",
    role: "Senior Policy Officer",
    org: "WIPO",
  },
  {
    quote: "The bespoke IP training program delivered to our legal team was outstanding. The practical framework provided has become the foundation of our entire trademark strategy.",
    name: "Nino Kvaratskhelia",
    role: "General Counsel",
    org: "TBC Group",
  },
  {
    quote: "Her guidance on cross-border dispute resolution saved us both time and considerable resources. A true expert who translates complex IP law into actionable business decisions.",
    name: "Sophie Laurent",
    role: "Chief Executive Officer",
    org: "Maison Laurent SARL",
  },
];
---

<section id="testimonials" class="py-28 bg-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Header -->
    <div class="reveal flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-16 pb-8 border-b border-cream-dark">
      <div>
        <p class="label mb-3">Testimonials</p>
        <h2 class="font-display font-black text-charcoal uppercase text-4xl sm:text-5xl leading-none tracking-tight">
          {t('testimonials.title')}
        </h2>
      </div>
      <p class="text-charcoal-muted text-sm leading-relaxed max-w-xs font-light">
        {t('testimonials.subtitle')}
      </p>
    </div>

    <!-- Grid -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-cream-dark border border-cream-dark">
      {testimonials.map(({ quote, name, role, org }, i) => (
        <article class={`p-8 lg:p-10 flex flex-col gap-8 ${i >= 2 ? 'border-t border-cream-dark' : ''}`}>
          <blockquote class="text-charcoal text-base leading-relaxed font-light flex-1">
            "{quote}"
          </blockquote>
          <div class="flex items-center gap-4 pt-6 border-t border-cream-dark">
            <div class="w-8 h-8 bg-charcoal flex items-center justify-center shrink-0">
              <span class="font-display font-bold text-cream text-xs">{name[0]}</span>
            </div>
            <div>
              <div class="font-display font-bold text-charcoal text-sm uppercase tracking-wide">{name}</div>
              <div class="font-display text-charcoal-muted text-xs uppercase tracking-widest mt-0.5">{role}, {org}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import { type Lang, useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    quote: "Working with this consultant transformed our approach to IP protection in the EU market. Her insights on acquis harmonization were invaluable for our expansion strategy.",
    name: "Dr. Andrea Müller",
    role: "Director of Legal Affairs",
    org: "European Pharmaceutical Group",
    initials: "AM",
  },
  {
    quote: "As a WIPO representative, I have collaborated alongside her at numerous international forums. Her expertise in GI frameworks and commitment to capacity building is unmatched in the region.",
    name: "James K. Osei",
    role: "Senior Policy Officer",
    org: "WIPO",
    initials: "JO",
  },
  {
    quote: "The bespoke IP training program delivered to our legal team was outstanding. The practical framework provided has become the foundation of our entire trademark strategy.",
    name: "Nino Kvaratskhelia",
    role: "General Counsel",
    org: "TBC Group",
    initials: "NK",
  },
  {
    quote: "Her guidance on cross-border dispute resolution saved us both time and considerable resources. A true expert who translates complex IP law into actionable business decisions.",
    name: "Sophie Laurent",
    role: "Chief Executive Officer",
    org: "Maison Laurent SARL",
    initials: "SL",
  },
];
---

<section id="testimonials" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block text-gold text-sm font-semibold uppercase tracking-widest mb-3">Testimonials</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-navy mb-4">
        {t('testimonials.title')}
      </h2>
      <p class="text-slate-500 text-lg max-w-2xl mx-auto">
        {t('testimonials.subtitle')}
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map(({ quote, name, role, org, initials }) => (
        <article class="bg-slate-50 border border-slate-100 rounded-2xl p-8 flex flex-col gap-6">
          <!-- Quote mark -->
          <svg class="w-8 h-8 text-gold/40" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Quote -->
          <blockquote class="text-slate-600 leading-relaxed italic flex-1">
            "{quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-4 pt-4 border-t border-slate-200">
            <div class="w-10 h-10 rounded-full bg-navy text-white flex items-center justify-center text-sm font-bold shrink-0">
              {initials}
            </div>
            <div>
              <div class="font-semibold text-navy text-sm">{name}</div>
              <div class="text-slate-500 text-xs">{role}, {org}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

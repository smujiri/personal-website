---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coming Soon — SM Consulting</title>
    <meta name="description" content="Strategic Intellectual Property Consulting. Launching soon." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      ::selection { background: #141414; color: #F4EEE4; }
      .anim-1 { animation: fadeIn  1.0s ease 0.1s both; }
      .anim-2 { animation: fadeIn  1.2s ease 0.2s both; }
      .anim-3 { animation: fadeIn  1.2s ease 0.4s both; }
      .anim-4 { animation: fadeUp  0.8s cubic-bezier(0.16,1,0.3,1) 0.3s both; }
      .anim-5 { animation: fadeUp  0.8s cubic-bezier(0.16,1,0.3,1) 0.45s both; }
      .anim-6 { animation: fadeUp  0.7s cubic-bezier(0.16,1,0.3,1) 0.6s both; }
      input::placeholder { color: #B8B4AC; }
      input:focus { border-color: #141414; outline: none; }
    </style>
  </head>

  <body class="min-h-screen bg-[#F4EEE4] text-[#141414] font-['Outfit',sans-serif] flex flex-col">

    <!-- Dark silk half (top) -->
    <div class="relative flex-1 flex flex-col">

      <!-- Top section: silk texture, like card front -->
      <div
        class="relative flex flex-col justify-between p-8 sm:p-12 min-h-[55vh] overflow-hidden"
        style="background-image: url('/silk.png'); background-size: cover; background-position: center;"
      >
        <div class="absolute inset-0 bg-black/50"></div>

        <!-- Brand top-left -->
        <div class="relative anim-1">
          <span class="font-bold text-white text-lg tracking-tight">
            SM <span class="font-light opacity-40">CONSULTING</span>
          </span>
        </div>

        <!-- Tagline top-right — large, confident -->
        <div class="relative flex justify-end anim-2">
          <p class="font-black text-white uppercase text-3xl sm:text-5xl text-right leading-none tracking-tight">
            PROTECT NOW.<br />LEAD TOMORROW.
          </p>
        </div>

        <!-- SM monogram bottom-left -->
        <div class="relative anim-3 select-none" aria-hidden="true">
          <span class="font-black text-white/15 leading-none uppercase"
            style="font-size: clamp(5rem, 18vw, 11rem); line-height: 1;">
            SM
          </span>
        </div>
      </div>

      <!-- Bottom section: cream, like card back -->
      <div class="bg-[#F4EEE4] px-8 sm:px-12 py-12 flex flex-col sm:flex-row items-start justify-between gap-10">

        <!-- Name block bottom-left (like the card) -->
        <div class="anim-4">
          <h1 class="font-black text-[#141414] uppercase text-4xl sm:text-6xl leading-none tracking-tight">
            SOPHIO MUJIRI
          </h1>
          <p class="font-medium text-[#6B6B6B] uppercase tracking-widest text-xs mt-3">
            Patent & Trademark Attorney
          </p>
        </div>

        <!-- Email capture top-right (like contact info on card) -->
        <div class="w-full sm:w-auto sm:min-w-[300px] anim-5">
          <div class="space-y-2 mb-8 text-xs font-semibold uppercase tracking-widest">
            <div class="flex gap-4">
              <span class="text-[#6B6B6B] w-6">L.</span>
              <span class="text-[#141414]">Tbilisi, Georgia · Madrid, Spain</span>
            </div>
            <div class="flex gap-4">
              <span class="text-[#6B6B6B] w-6">E.</span>
              <a href="mailto:sophio@mujiri.ge" class="text-[#141414] hover:text-[#6B6B6B] transition-colors">
                sophio@mujiri.ge
              </a>
            </div>
            <div class="flex gap-4">
              <span class="text-[#6B6B6B] w-6">W.</span>
              <span class="text-[#141414]">Launching soon</span>
            </div>
          </div>

          <form id="notify-form" class="flex flex-col gap-3" novalidate>
            <label for="notify-email" class="sr-only">Email address</label>
            <input
              id="notify-email"
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full border border-[#D8D0C4] bg-transparent text-[#141414] placeholder-[#B8B4AC] px-4 py-3 text-xs font-semibold uppercase tracking-widest focus:outline-none focus:border-[#141414] transition-colors"
            />
            <button
              type="submit"
              class="w-full bg-[#141414] text-[#F4EEE4] font-bold text-xs uppercase tracking-widest px-6 py-3 hover:bg-[#252525] transition-colors"
            >
              Notify me at launch
            </button>
          </form>

          <p id="notify-success" class="hidden font-semibold text-[#141414] uppercase tracking-widest text-xs mt-4">
            You're on the list.
          </p>

          <p class="font-medium text-[#B8B4AC] uppercase tracking-widest text-xs mt-3">
            No spam. Launch update only.
          </p>
        </div>
      </div>
    </div>

    <script>
      const form = document.getElementById('notify-form') as HTMLFormElement | null;
      const success = document.getElementById('notify-success');
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
        if (!email || !email.includes('@')) return;
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      });
    </script>
  </body>
</html>

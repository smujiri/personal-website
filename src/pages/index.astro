---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coming Soon — SM Consulting</title>
    <meta name="description" content="Strategic Intellectual Property Consulting. Launching soon." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-navy min-h-screen flex flex-col items-center justify-center px-4 text-center relative overflow-hidden">

    <!-- Background glow -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 70% 60% at 60% 40%, rgba(196,168,75,0.08) 0%, transparent 70%), radial-gradient(ellipse 40% 60% at 10% 80%, rgba(29,83,154,0.25) 0%, transparent 60%)"
      aria-hidden="true"
    ></div>

    <div class="relative w-full max-w-xl">

      <!-- Brand -->
      <a href="/" class="font-serif text-2xl font-bold text-white inline-block mb-12">
        SM <span class="text-gold">Consulting</span>
      </a>

      <!-- Divider -->
      <div class="w-10 h-px bg-gold/50 mx-auto mb-12"></div>

      <!-- Headline -->
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white leading-tight mb-5">
        Something exceptional<br/>is coming.
      </h1>

      <p class="text-slate-400 text-lg font-light leading-relaxed mb-12 max-w-md mx-auto">
        A new standard in Intellectual Property advisory — strategic, commercial, and built on 20 years of institutional expertise.
      </p>

      <!-- Email form -->
      <form id="notify-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-md mx-auto mb-4" novalidate>
        <label for="notify-email" class="sr-only">Email address</label>
        <input
          id="notify-email"
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 bg-white/8 border border-white/15 text-white placeholder-slate-500 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:border-gold/60 focus:ring-1 focus:ring-gold/30 transition-colors"
        />
        <button
          type="submit"
          class="bg-gold hover:bg-gold-light text-navy font-bold px-6 py-3.5 rounded-xl text-sm transition-colors whitespace-nowrap"
        >
          Notify me
        </button>
      </form>

      <!-- Success -->
      <p id="notify-success" class="hidden text-gold text-sm font-medium mb-4">
        You're on the list — we'll be in touch.
      </p>

      <p class="text-slate-600 text-xs">No spam. Just the launch announcement.</p>

      <!-- Institution strip -->
      <div class="mt-16 pt-8 border-t border-white/8 flex flex-wrap justify-center items-center gap-8">
        {['EUIPO', 'WIPO', 'INTA', 'SAKPATENTI'].map(org => (
          <span class="text-white/25 text-sm font-semibold tracking-widest">{org}</span>
        ))}
      </div>
    </div>

    <script>
      const form = document.getElementById('notify-form') as HTMLFormElement | null;
      const success = document.getElementById('notify-success');

      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
        if (!email || !email.includes('@')) return;
        // TODO: connect to your email provider
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      });
    </script>
  </body>
</html>

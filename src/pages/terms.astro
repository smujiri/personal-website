---
import Layout from '../layouts/Layout.astro';

const lang = 'en';
---

<Layout lang={lang} title="Terms & Conditions — IP Consulting" description="Terms and conditions governing the use of this website and advisory services.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <h1 class="font-serif text-4xl font-bold text-navy mb-4">Terms & Conditions</h1>
    <p class="text-slate-500 text-sm mb-12">Last updated: January 2025</p>

    <div class="space-y-8">
      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">1. Acceptance of Terms</h2>
        <p class="text-slate-600 leading-relaxed">By accessing this website, you agree to be bound by these Terms & Conditions and our Privacy Policy. If you do not agree, please do not use this site.</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">2. Services</h2>
        <p class="text-slate-600 leading-relaxed">This website provides information about intellectual property advisory services. Initial consultations booked via this website are provided as an introduction to our services and do not constitute legal advice or create a client-advisor relationship unless a formal engagement agreement is signed.</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">3. Intellectual Property</h2>
        <p class="text-slate-600 leading-relaxed">All content on this website — including text, graphics, and design — is the exclusive property of [Consultant Name] and is protected by applicable copyright law. No content may be reproduced without prior written permission.</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">4. Limitation of Liability</h2>
        <p class="text-slate-600 leading-relaxed">The information on this website is provided for general informational purposes only and does not constitute legal advice. We make no representations or warranties regarding its accuracy or completeness. Use of this information is at your own risk.</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">5. Governing Law</h2>
        <p class="text-slate-600 leading-relaxed">These terms are governed by and construed in accordance with the laws of [Jurisdiction]. Any disputes arising shall be subject to the exclusive jurisdiction of the courts of [Jurisdiction].</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">6. Changes to Terms</h2>
        <p class="text-slate-600 leading-relaxed">We reserve the right to update these terms at any time. Continued use of the website following changes constitutes acceptance of the revised terms.</p>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-semibold text-navy mb-3">7. Contact</h2>
        <p class="text-slate-600 leading-relaxed">
          For questions about these terms, contact us at: <a href="mailto:contact@example.com" class="text-gold hover:underline">contact@example.com</a>
        </p>
      </section>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-100">
      <a href="/" class="inline-flex items-center gap-2 text-navy font-medium hover:text-gold transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
        Back to home
      </a>
    </div>
  </div>
</Layout>
